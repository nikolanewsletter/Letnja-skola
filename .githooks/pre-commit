#!/bin/sh
set -eu

blocked_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '(^|/)\.env($|[.])' || true)

if [ -n "$blocked_files" ]; then
  echo "Refusing to commit environment files:" >&2
  echo "$blocked_files" >&2
  echo "Keep secrets in local .env files and commit only safe templates like .env.example." >&2
  exit 1
fi
